{
  "name": "xei-001-gold-master",
  "version": "1.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run validate",
    "test:production": "node tests/validate.mjs",
    "test:continuum-structure": "node tests/continuum-structure.mjs",
    "test:continuum": "vitest run --config continuum/vitest.config.ts",
    "typecheck:continuum": "tsc -p continuum/tsconfig.json --noEmit",
    "validate": "npm run test:production && npm run test:continuum-structure && npm run typecheck:continuum && npm run test:continuum",
    "certify": "npm run validate",
    "cf:typegen": "wrangler types --config continuum/wrangler.jsonc continuum/worker-configuration.d.ts",
    "cf:migrate:local": "wrangler d1 migrations apply xen-continuum-local --local --config continuum/wrangler.jsonc",
    "cf:dry-run": "wrangler deploy --dry-run --config continuum/wrangler.jsonc",
    "cf:dry-run:staging": "wrangler deploy --dry-run --env staging --config continuum/wrangler.jsonc"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "jose": "^6.1.3"
  }
}
